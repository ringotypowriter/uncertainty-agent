{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Final Measurement Uncertainty Report Artifacts",
  "description": "基于合成与扩展产物形成最终报告陈述、预算表和生成制品内容。",
  "type": "object",
  "required": ["report_expression", "uncertainty_budget", "final_statement", "artifacts", "quality_review"],
  "properties": {
    "report_metadata": {
      "type": "object",
      "description": "报告元数据和方法引用信息",
      "properties": {
        "report_id": { "type": "string" },
        "analyst": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "method_reference": { "type": "string", "description": "引用的SOP或标准编号" }
      }
    },
    "measurand_specification": {
      "type": "object",
      "description": "最终报告使用的被测量、测量模型、单位和计算基础",
      "properties": {
        "description": { "type": "string" },
        "equation": { "type": "string" },
        "output_symbol": { "type": "string" },
        "output_unit": { "type": "string" },
        "calculation_basis": { "type": "string" }
      }
    },
    "report_expression": {
      "type": "object",
      "description": "最终测量结果、不确定度、单位、包含因子或包含概率的报告表达",
      "properties": {
        "measured_value_y": { "type": "number", "description": "被测量的最佳估计值" },
        "combined_standard_uncertainty_uc": { "type": "number", "description": "合成标准不确定度 uc(y)" },
        "coverage_factor_k": { "type": "number", "description": "包含因子 k" },
        "expanded_uncertainty_U": { "type": "number", "description": "扩展不确定度 U" },
        "confidence_level": { "type": "string", "description": "置信水平" },
        "unit": { "type": "string" }
      }
    },
    "uncertainty_budget": {
      "type": "array",
      "description": "用于报告的不确定度预算表或结构化预算数据",
      "items": {
        "type": "object",
        "properties": {
          "source_label": { "type": "string" },
          "value_xi": { "type": "number" },
          "standard_uncertainty_ui": { "type": "number" },
          "sensitivity_coefficient_ci": { "type": "number" },
          "contribution_ui_y": { "type": "number" },
          "relative_contribution_percent": { "type": "number" },
          "distribution": { "type": "string" },
          "unit": { "type": "string" }
        }
      }
    },
    "final_statement": {
      "type": "object",
      "description": "按照规范生成的最终结论陈述",
      "required": ["formatted_result", "standard_text"],
      "properties": {
        "formatted_result": { "type": "string", "description": "例如：'(3.52 ± 0.14) g/100 g'" },
        "standard_text": {
          "type": "string",
          "description": "完整的标准声明，说明所报告的不确定度、包含因子和置信水平"
        },
        "compliance_assessment": {
          "type": "object",
          "description": "判定测量结果是否符合限值要求（可选）",
          "properties": {
            "limit": { "type": "number" },
            "decision_rule": { "type": "string" },
            "is_compliant": { "type": "boolean" }
          }
        }
      }
    },
    "artifacts": {
      "type": "object",
      "description": "生成制品的结构化内容、文件计划、表格、说明和可追溯记录",
      "properties": {
        "tables": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "description": { "type": "string" },
              "rows": { "type": "array", "items": { "type": "object", "additionalProperties": true } }
            }
          }
        },
        "figures": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "title": { "type": "string" },
              "description": { "type": "string" },
              "data": { "type": "object", "additionalProperties": true }
            }
          }
        },
        "file_plan": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "path": { "type": "string" },
              "purpose": { "type": "string" },
              "content_summary": { "type": "string" }
            }
          }
        }
      }
    },
    "quality_review": {
      "type": "object",
      "description": "报告一致性、修约、单位、待定项和可追溯性的最终检查",
      "properties": {
        "rounding_check": { "type": "string" },
        "unit_check": { "type": "string" },
        "traceability_check": { "type": "string" },
        "limitations": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
