{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Measurand Specification",
  "description": "定义被测量的本质属性与边界",
  "type": "object",
  "required": [
    "clear_statement",
    "kind_of_quantity",
    "analyte",
    "method_nature"
  ],
  "properties": {
    "clear_statement": {
      "type": "string",
      "description": "无歧义的陈述，例如：'面包样本中有机磷农药的质量分数' "
    },
    "kind_of_quantity": {
      "type": "string",
      "description": "量的种类，如浓度、质量分数、pH值、颜色等 "
    },
    "analyte": {
      "type": "string",
      "description": "拟测量的特定化学品种 "
    },
    "matrix": {
      "type": "object",
      "description": "携带该量的物体或材料 ",
      "properties": {
        "material": {
          "type": "string",
          "description": "材料名称（如：陶瓷器皿）"
        },
        "location": {
          "type": "string",
          "description": "取样具体位置或部位"
        },
        "state": { "type": "string", "description": "测量时的状态描述" }
      }
    },
    "calculation_basis": {
      "type": "string",
      "description": "报告结果的基础，如：'基于干重'、'提取条件下的量'"
    },
    "sampling_scope": {
      "type": "object",
      "description": "采样步骤的界定",
      "properties": {
        "is_included": {
          "type": "boolean",
          "description": "被测量定义是否包含采样步骤"
        },
        "boundary": {
          "type": "string",
          "description": "指向'整体大宗物料'还是'实验室测试样品'"
        }
      }
    },
    "method_nature": {
      "type": "object",
      "description": "区分方法依赖性",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["Rational", "Empirical"],
          "description": "Rational（有理/非经验）：结果独立于方法；Empirical（经验）：被测量由程序定义"
        },
        "procedure_reference": {
          "type": "string",
          "description": "对于经验方法，必须注明的标准编号或SOP"
        }
      }
    }
  }
}
